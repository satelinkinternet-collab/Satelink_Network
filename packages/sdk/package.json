{
  "name": "@satelink/sdk",
  "version": "0.1.0",
  "description": "Official SDK for the Satelink DePIN network — RPC, AI inference, and blockchain tools",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./rpc": {
      "import": "./dist/rpc.js",
      "types": "./dist/rpc.d.ts"
    },
    "./ai": {
      "import": "./dist/ai.js",
      "types": "./dist/ai.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "echo 'Skipped (TypeScript handles linting)'",
    "test": "vitest"
  },
  "keywords": [
    "satelink",
    "depin",
    "rpc",
    "ethereum",
    "polygon",
    "blockchain",
    "ai",
    "openai",
    "langchain"
  ],
  "author": "Satelink Network",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/satelinkinternet-collab/Satelink_Network.git"
  },
  "homepage": "https://satelink.network",
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "viem": ">=2.0.0",
    "wagmi": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "viem": { "optional": true },
    "wagmi": { "optional": true }
  }
}
