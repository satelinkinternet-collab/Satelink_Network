# Satelink Network - Local Development Environment Variables

NODE_ENV=development
PORT=8080

# ── Security Secrets (ALL REQUIRED — no fallbacks) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev_secret_keys_only_for_local_use_must_be_at_least_64_characters_long_for_hs256
JWT_REFRESH_SECRET=dev_refresh_secret_keys_only_for_local_use_must_be_at_least_32_chars
IP_HASH_SALT=dev_ip_hash_salt_change_in_production
PASSWORD_SALT=dev_password_salt_change_in_production
ADMIN_API_KEY=dev_admin_api_key_change_in_production

# ── Database ──
SQLITE_PATH=./data/satelink.db
# Set DATABASE_URL for PostgreSQL (required in production):
# DATABASE_URL=postgresql://satelink:satelink@localhost:5432/satelink

# ── Cache ──
REDIS_URL=redis://localhost:6379

# ── Settlement ──
SETTLEMENT_INTERVAL_MS=60000
SETTLEMENT_BATCH_SIZE=20
FEATURE_REAL_SETTLEMENT=false

# Active settlement adapter: polygon | fuse (deprecated) | evm | shadow | simulated
SETTLEMENT_ADAPTER=polygon

# ── Polygon PoS (primary chain) ──
# Mainnet: https://polygon-rpc.com   chain id 137   USDT 0xc2132D05D31c914a87C6611C10748AEb04B58e8F
# Amoy testnet: https://rpc-amoy.polygon.technology   chain id 80002
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_CHAIN_ID=137
POLYGON_USDT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
POLYGON_USDT_DECIMALS=6
# POLYGON_SIGNER_KEY=

# ── Fuse Network (DEPRECATED — low liquidity) ──
# Kept only for legacy migrations. New deploys should use Polygon.
# FUSE_RPC_URL=https://rpc.fuse.io
# FUSE_CHAIN_ID=122
# FUSE_USDT_ADDRESS=
# FUSE_SIGNER_KEY=

# ── Epoch & Scheduler ──
EPOCH_DURATION=3600

# ── Demand Flywheel ──
FLYWHEEL_ENABLED=true
FLYWHEEL_MAX_FOLLOWUPS=5
FLYWHEEL_MAX_JOBS_PER_MIN=200

# ── Smart Contracts (Polygon PoS) ──
# USDT_CONTRACT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
# TREASURY_ADDRESS=0x...
# NEXT_PUBLIC_CLAIMS_CONTRACT=0x...

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# NEXT_PUBLIC_ADMIN_KEY=  (set for admin dashboard access)

# ── Docker Override (set by docker-compose) ──
# INTERNAL_API_URL=http://api:8080

# ── Worker ──
WORKER_CONCURRENCY=5
WORKER_INTERVAL_MS=60000
