# ─────────────────────────────────────────────────────────────
# Satelink MVP — Environment Configuration
# Copy this file to .env and fill in the values.
# All variables without defaults are REQUIRED.
# ─────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ── Database ──────────────────────────────────────────────────
# DB_TYPE: "sqlite" (dev) or "postgres" (production)
DB_TYPE=sqlite
SQLITE_PATH=satelink.db
# DATABASE_URL is required when DB_TYPE=postgres
# DATABASE_URL=postgres://user:pass@localhost:5432/satelink

# ── Authentication (REQUIRED) ────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_TTL=3600
JWT_ISSUER=satelink

# ── Admin Security (REQUIRED) ────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=

# ── Privacy / Hashing ────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
IP_HASH_SALT=
PASSWORD_SALT=

# ── Rate Limiting ─────────────────────────────────────────────
AUTH_RATE_LIMIT_PER_MIN=10

# ── Blockchain / Settlement ───────────────────────────────────
# SATELINK_MODE: "simulation" (default, safe) or "live" (real blockchain)
SATELINK_MODE=simulation
# Required for live settlement:
# TREASURY_PRIVATE_KEY=
# FUSE_RPC_URL=https://rpc.fuse.io
# USDT_CONTRACT_ADDRESS=
# NODE_REGISTRY_ADDRESS=
# REVENUE_VAULT_ADDRESS=
# CLAIMS_CONTRACT_ADDRESS=
# REVENUE_DISTRIBUTOR_ADDRESS=
# SPLIT_ENGINE_ADDRESS=
# EPOCH_ANCHOR_ADDRESS=

# ── External Integrations ────────────────────────────────────
# MoonPay (fiat on-ramp)
# MOONPAY_WEBHOOK_SECRET=
# MOONPAY_SIG_MODE=raw

# NodeOps (managed nodes)
# NODEOPS_API_KEY=

# Fuse Webhooks
# FUSE_WEBHOOK_IP_ALLOWLIST=

# ── Frontend (NEXT_PUBLIC_ prefix for client-side access) ────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# NEXT_PUBLIC_ADMIN_KEY= (only if admin dashboard needs API access)
