# ═══════════════════════════════════════
# SATELINK — ENVIRONMENT VARIABLES
# Copy to .env and fill in real values
# NEVER commit .env to git
# ═══════════════════════════════════════

# ── CORE ────────────────────────────
NODE_ENV=development
PORT=8081
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX

# ── DATABASE (PostgreSQL ONLY) ──────
# NO SQLITE — use PostgreSQL in all environments
DATABASE_URL=postgresql://user:password@localhost:5432/satelink

# ── REDIS ───────────────────────────
REDIS_URL=redis://localhost:6379

# ── BLOCKCHAIN ──────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
ALCHEMY_API_KEY=REPLACE_WITH_ALCHEMY_KEY
ALCHEMY_POLYGON_KEY=REPLACE_WITH_ALCHEMY_POLYGON_KEY

# ── WALLET / SIGNING ────────────────
TREASURY_ADDRESS=REPLACE_WITH_WALLET_ADDRESS
POLYGON_SIGNER_KEY=REPLACE_WITH_64_CHAR_HEX
SETTLEMENT_EVM_SIGNER_PRIVATE_KEY=REPLACE_WITH_64_CHAR_HEX

# ── CONTRACTS ───────────────────────
CLAIMS_CONTRACT_ADDRESS=0x_REPLACE_WITH_DEPLOYED_CLAIMS_CONTRACT
POLYGON_USDT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
POLYGON_CHAIN_ID=137
POLYGON_USDT_DECIMALS=6

# ── NODE IDENTITY ───────────────────
NODE_ID=NODE-your-region-your-node-id
NODE_REGION=your-region
SATELINK_MODE=production

# ── SETTLEMENT ──────────────────────
SETTLEMENT_INTERVAL_MS=60000
SETTLEMENT_BATCH_SIZE=20
FEATURE_REAL_SETTLEMENT=false
SETTLEMENT_ADAPTER=polygon
SETTLEMENT_MAX_BATCH_ITEMS=20
SETTLEMENT_MAX_BATCH_USDT=50.0
SETTLEMENT_FAILOVER_MAX_FAILURES=5
SETTLEMENT_RETRY_INTERVAL_MS=30000
SETTLEMENT_SHADOW_TIMEOUT_MS=10000

# ── EPOCH & SCHEDULER ───────────────
EPOCH_DURATION=3600

# ── DEMAND FLYWHEEL ─────────────────
FLYWHEEL_ENABLED=true
FLYWHEEL_MAX_FOLLOWUPS=5
FLYWHEEL_MAX_JOBS_PER_MIN=200

# ── EXTERNAL APIS ───────────────────
ANKR_API_KEY=REPLACE_WITH_ANKR_KEY
GROQ_API_KEY=REPLACE_WITH_GROQ_KEY

# ── ADMIN ───────────────────────────
MASTER_ADMIN_TOKEN=REPLACE_WITH_64_CHAR_HEX
ADMIN_API_KEY=REPLACE_WITH_ADMIN_KEY

# ── WORKER ──────────────────────────
WORKER_CONCURRENCY=5
WORKER_INTERVAL_MS=60000

# ── REPUTATION ENGINE (do not publish real values) ──
REP_WEIGHT_UPTIME=0.30
REP_WEIGHT_LATENCY=0.25
REP_WEIGHT_RELIABILITY=0.20
REP_WEIGHT_REVENUE=0.15
REP_WEIGHT_FRAUD_INV=0.10

# ── FRONTEND (prefix NEXT_PUBLIC_) ──
NEXT_PUBLIC_API_URL=http://localhost:8081
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081
NEXT_PUBLIC_WALLETCONNECT_ID=REPLACE_WITH_WALLETCONNECT_PROJECT_ID
