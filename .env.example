# Satelink Network - Local Development Environment Variables

NODE_ENV=development
PORT=8080

# Secrets (DO NOT use these in production)
JWT_SECRET=dev_secret_keys_only_for_local_use
IP_HASH_SALT=dev_salt_1
PASSWORD_SALT=dev_salt_2

# Database
SQLITE_PATH=./data/satelink.db
DATABASE_URL=postgresql://satelink:satelink@localhost:5432/satelink

# Cache
REDIS_URL=redis://localhost:6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
