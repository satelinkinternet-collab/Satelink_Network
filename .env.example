# ── Satelink Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in the values before starting the server.
# Never commit .env to version control.

# ── Mode ─────────────────────────────────────────────────────────────────────
# simulate | live
SATELINK_MODE=simulate
NODE_ENV=development
PORT=8080

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (default for dev)
DB_TYPE=sqlite
SQLITE_PATH=satelink.db
# DATABASE_URL=postgresql://user:password@localhost:5432/satelink

# ── Authentication (REQUIRED) ────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ISSUER=satelink-network
JWT_TTL=15m
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_REFRESH_TTL=7d
PASSWORD_SALT=change_me_to_a_random_salt

# ── Admin API Key (REQUIRED) ─────────────────────────────────────────────────
ADMIN_API_KEY=change_me_to_a_strong_api_key

# ── Security ─────────────────────────────────────────────────────────────────
# Salt used for IP anonymisation in rate limiting (REQUIRED in production)
IP_HASH_SALT=change_me_to_a_random_salt
IP_SALT=change_me_to_a_random_salt
AUTH_RATE_LIMIT_PER_MIN=10

# ── Blockchain / Settlement ───────────────────────────────────────────────────
FUSE_RPC_URL=https://rpc.fusespark.io
FUSE_CHAIN_ID=123
FUSE_USDT_CONTRACT=0x0000000000000000000000000000000000000000
FUSE_WEBHOOK_IP_ALLOWLIST=
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
TREASURY_MANAGED=false
TREASURY_ROUTER=

REVENUE_VAULT_CONTRACT=0x0000000000000000000000000000000000000000
EPOCH_ANCHOR_CONTRACT=0x0000000000000000000000000000000000000000
EPOCH_DURATION=3600

# EVM Settlement Driver
SETTLEMENT_EVM_ENABLED=false
SETTLEMENT_EVM_DRIVER=fuse
SETTLEMENT_EVM_CHAIN_NAME=fuse_spark
SETTLEMENT_EVM_RPC_URL=https://rpc.fusespark.io
SETTLEMENT_EVM_NATIVE_SYMBOL=FUSE
SETTLEMENT_EVM_SIGNER_PRIVATE_KEY=
SETTLEMENT_EVM_TOKEN_MAP_JSON=
SETTLEMENT_CONFIRMATIONS=2
SETTLEMENT_MAX_BATCH_USDT=10000

# OpenZeppelin Defender (optional, for relayed transactions)
DEFENDER_KEY=
DEFENDER_SECRET=

# ── NodeOps Integration ───────────────────────────────────────────────────────
NODEOPS_API_KEY=
NODEOPS_BASE_URL=https://api.nodeops.io
NODEOPS_AUTH_MODE=api_key
NODEOPS_ORG_ID=
NODEOPS_WORKSPACE_ID=
NODEOPS_TIMEOUT_MS=10000
NODEOPS_MAX_RETRIES=3
NODEOPS_CREATEOS_API_KEY=
NODEOPS_CREATEOS_BASE_URL=

# ── MoonPay Webhooks ──────────────────────────────────────────────────────────
MOONPAY_WEBHOOK_SECRET=
MOONPAY_SIG_MODE=raw

# ── Notifications ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Relayer ───────────────────────────────────────────────────────────────────
RELAYER_API_KEY=
RELAYER_API_SECRET=

# ── Staging / Diagnostics ─────────────────────────────────────────────────────
# STAGING_MODE=true
# STAGING_BASIC_USER=admin
# STAGING_BASIC_PASS=change_me
# CORS_ORIGINS=https://app.satelink.io
# ENABLE_DEBUG_LOGGING=false

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_REAL_SETTLEMENT=false
FLAG_DISABLE_ADMIN_DIAGNOSTICS=false
FLAG_DISABLE_RPC=false
FLAG_DISABLE_SIMULATION_ROUTES=false
FLAG_READONLY_MODE=false
