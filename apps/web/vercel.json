{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app.satelink.network" }],
      "destination": "/satelink/os/overview/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "status.satelink.network" }],
      "destination": "/status"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "app.satelink.network" }],
      "destination": "/satelink/os/overview",
      "permanent": false
    }
  ]
}
