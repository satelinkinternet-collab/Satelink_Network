{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app.satelink.network" }],
      "destination": "/satelink/os/overview/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "status.satelink.network" }],
      "destination": "/_status/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "app.satelink.network" }],
      "destination": "/satelink/os/overview",
      "permanent": false
    },
    {
      "source": "/status",
      "missing": [{ "type": "host", "value": "status.satelink.network" }],
      "destination": "https://status.satelink.network/",
      "permanent": true
    },
    {
      "source": "/status/",
      "missing": [{ "type": "host", "value": "status.satelink.network" }],
      "destination": "https://status.satelink.network/",
      "permanent": true
    },
    {
      "source": "/status/:path*",
      "missing": [{ "type": "host", "value": "status.satelink.network" }],
      "destination": "https://status.satelink.network/:path*",
      "permanent": true
    }
  ]
}
