  "scripts": {
    "dev": "NODE_ENV=development nodemon server.js",
    "start": "NODE_ENV=production node server.js",
    "lint": "eslint .",
    "test": "NODE_ENV=test ADMIN_API_KEY=test-admin-secret-012345678901234567890123456789012345678901234567890 JWT_SECRET=test-jwt-secret-012345678901234567890123456789012345678901234567890123456789 mocha test/**/*.test.js",
    "dev:all": "bash dev.sh",
    "dev:backend": "node server.js",
    "dev:frontend": "cd web && npm run dev",
    "dev:full": "bash dev.sh",
    "contracts:build": "forge build",
    "contracts:test": "forge test -vv",
    "contracts:deploy:local": "forge script script/Deploy.s.sol --rpc-url localhost --broadcast",
    "contracts:deploy:spark": "forge script script/Deploy.s.sol --rpc-url fuse_spark --broadcast",
    "e2e:manual": "bash scripts/manual_e2e.sh",
    "test:all": "bash scripts/test.sh",
    "migrate": "node scripts/migrate.js",
    "self:test": "node tools/self_test.js",
    "self:heal": "node tools/self_heal.js",
    "ops:triage": "node src/ops-agent/triage.js",
    "deploy:settlement": "node scripts/deploy_settlement.js",
    "smoke:settlement": "node scripts/smoke_settlement.js"
  },
  "description": "This project has a minimal setup of Hardhat 3 Beta, without any plugins.",
