{
  "name": "satelink-provider",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "agents/*"
  ],
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^8.0.0",
    "turbo": "^2.1.2",
    "typescript": "~5.8.0"
  },
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently \"npm run dev --workspace=@satelink/api\" \"npm run dev --workspace=web\"",
    "dev:api": "npm run dev --workspace=@satelink/api",
    "dev:dashboard": "npm run dev --workspace=web",
    "build": "turbo build --filter=web --filter=@satelink/api",
    "test": "turbo test --filter=web",
    "lint": "turbo lint",
    "contracts:build": "forge build",
    "contracts:test": "forge test -vv",
    "contracts:deploy:local": "forge script script/Deploy.s.sol --rpc-url localhost --broadcast",
    "contracts:deploy:spark": "forge script script/Deploy.s.sol --rpc-url fuse_spark --broadcast",
    "start": "node apps/api/server.js",
    "gateway": "node apps/api/gateway.js",
    "worker": "node apps/api/worker.js",
    "certify": "mkdir -p logs && node scripts/certify_satelink.js",
    "soak-test": "bash scripts/run_72h_test.sh --local",
    "soak-test:1h": "DURATION_HOURS=1 bash scripts/run_72h_test.sh --local",
    "soak-test:docker": "bash scripts/run_72h_test.sh",
    "deploy": "bash scripts/deploy.sh",
    "deploy:skip-cert": "bash scripts/deploy.sh --skip-cert"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@tanstack/react-query": "^5.100.10",
    "@vercel/analytics": "^2.0.1",
    "@xyflow/react": "^12.10.2",
    "cmdk": "^1.1.1",
    "lightningcss": "^1.32.0",
    "pino-pretty": "^13.1.3",
    "zustand": "^5.0.13"
  }
}
