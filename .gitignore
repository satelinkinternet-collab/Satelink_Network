node_modules/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/cache
.yarn/unplugged

# ── BUILD OUTPUTS ────────────────────
dist/
build/
.next/
out/
.turbo/
*.tsbuildinfo
.cache/

# ── FOUNDRY / SOLIDITY ───────────────
cache/
broadcast/
out/
!broadcast/*/31337/
!broadcast/**/dry-run/
typechain-types/

# ── DATABASE ─────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-shm
*.db-wal
dump.rdb
*.rdb

