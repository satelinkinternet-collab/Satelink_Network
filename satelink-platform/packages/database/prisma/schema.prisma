generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  role      String     @default("operator") // enterprise, operator
  createdAt DateTime   @default(now())
  nodes     Node[]
  workloads Workload[]
}

model Node {
  id              String         @id @default(uuid())
  operatorId      String
  operator        User           @relation(fields: [operatorId], references: [id])
  status          String         @default("offline") // online, offline, busy
  uptimeScore     Float          @default(1.0)
  reputationScore Float          @default(0.6)
  lastSeen        DateTime       @default(now())
  jobs            Job[]
  revenue         RevenueEvent[]
}

model Workload {
  id        String   @id @default(uuid())
  creatorId String
  creator   User     @relation(fields: [creatorId], references: [id])
  type      String   // rpc, webhook, compute, automation
  payload   Json
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  jobs      Job[]
}

model Job {
  id          String      @id @default(uuid())
  workloadId  String
  workload    Workload    @relation(fields: [workloadId], references: [id])
  nodeId      String?
  node        Node?       @relation(fields: [nodeId], references: [id])
  status      String      @default("pending") // pending, executing, completed, failed
  startedAt   DateTime?
  completedAt DateTime?
  results     JobResult[]
}

model JobResult {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  output    Json
  createdAt DateTime @default(now())
}

model RevenueEvent {
  id        String   @id @default(uuid())
  nodeId    String
  node      Node     @relation(fields: [nodeId], references: [id])
  amount    Float
  epochId   String
  createdAt DateTime @default(now())
}

model APIKey {
  id        String   @id @default(uuid())
  key       String   @unique
  ownerId   String
  createdAt DateTime @default(now())
}

model Metric {
  id        String   @id @default(uuid())
  name      String
  value     Float
  timestamp DateTime @default(now())
}

model EpochSnapshot {
  id        String   @id
  startTime DateTime
  endTime   DateTime
  status    String   // open, closed, settled
  createdAt DateTime @default(now())
}
