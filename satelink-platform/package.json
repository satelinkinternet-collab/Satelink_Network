{
    "name": "satelink-platform",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "apps/*",
        "services/*",
        "packages/*",
        "agents/*"
    ],
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "dev": "npm run dev --workspaces --if-present",
        "lint": "npm run lint --workspaces --if-present",
        "typecheck": "npm run typecheck --workspaces --if-present",
        "db:push": "npm run db:push --workspace=@satelink/database",
        "db:generate": "npm run db:generate --workspace=@satelink/database"
    },
    "devDependencies": {
        "turbo": "^2.1.2",
        "typescript": "^5.5.4"
    }
}